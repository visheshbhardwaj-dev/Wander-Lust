<% layout("/layouts/boilerplate") %>
<h3 class=" mt-4 mb-4 text-capitalize">
  <b>Search results for:</b> <%= category %>
</h3>

<% if (foundListing.length === 0) { %>

  <div class="d-flex flex-column align-items-center justify-content-center text-center py-5" style="min-height: 50vh;">
    <i class="fa-regular fa-face-frown fa-3x mb-3 text-secondary"></i>
    <h5 class="fw-bold">No listings found</h5>
    <p class="text-muted mb-3">
      Looks like there are no stays in this category right now.
    </p>
    <a href="/listings" class="btn btn-outline-dark px-4">
      Browse All Listings
    </a>
  </div>

<% } else { %>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

    <% for (let listing of foundListing) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="col">
          <div class="card h-100">
            <img src="<%= listing.image.url %>"
                 class="card-img-top"
                 style="height:200px; object-fit:cover;">
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= listing.title %></h5>
              <p class="card-text">
                ₹ <%= listing.price.toLocaleString("en-IN") %>/night
              </p>
            </div>
          </div>
        </div>
      </a>
    <% } %>

  </div>

<% } %>
